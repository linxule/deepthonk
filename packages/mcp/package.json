{
  "name": "@deepthonk/mcp",
  "version": "0.3.0",
  "description": "MCP server adapter for DeepThonk.",
  "license": "MIT",
  "author": "Xule Lin",
  "homepage": "https://github.com/linxule/deepthonk#readme",
  "bugs": {
    "url": "https://github.com/linxule/deepthonk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linxule/deepthonk.git",
    "directory": "packages/mcp"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE"
  },
  "dependencies": {
    "@deepthonk/core": "workspace:*",
    "@deepthonk/providers": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.7.1",
    "zod": "^4.4.3"
  }
}
