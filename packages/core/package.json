{
  "name": "@deepthonk/core",
  "version": "0.1.3",
  "description": "Core OpenDeepThink execution engine for DeepThonk.",
  "license": "MIT",
  "author": "Xule Lin",
  "homepage": "https://github.com/linxule/deepthonk#readme",
  "bugs": {
    "url": "https://github.com/linxule/deepthonk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linxule/deepthonk.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE"
  },
  "dependencies": {
    "p-limit": "^6.2.0",
    "zod": "^3.25.28"
  }
}
