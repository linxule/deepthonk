{
  "name": "@deepthonk/cli",
  "version": "0.1.0",
  "description": "DeepThonk command-line interface and MCP server launcher.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "deepthonk": "dist/index.js",
    "dt": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xulelin/deepthonk.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deepthonk": "tsx src/index.ts"
  },
  "dependencies": {
    "@deepthonk/core": "workspace:*",
    "@deepthonk/mcp": "workspace:*",
    "@deepthonk/providers": "workspace:*",
    "commander": "^13.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.28"
  }
}
