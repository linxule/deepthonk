{
  "name": "deepthonk-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Provider-neutral OpenDeepThink CLI and MCP server.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/linxule/deepthonk.git"
  },
  "keywords": [
    "opendeepthink",
    "reasoning",
    "mcp",
    "cli",
    "deepseek"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "bench": "pnpm run build && node --expose-gc scripts/bench.mjs",
    "bench:ci": "pnpm run build && node --expose-gc scripts/bench.mjs --ci",
    "test": "vitest run",
    "lint": "pnpm -r run typecheck",
    "typecheck": "pnpm -r run typecheck",
    "smoke:dist": "pnpm run build && node packages/cli/dist/index.js plan --profile paper"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod-to-json-schema": "^3.25.2"
  }
}
